{
  "name": "dominion",
  "version": "1.0.0",
  "main": "run.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "jest",
    "static": "eslint *.js src",
    "mutation": "npx stryker run --incremental"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.12.11",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/jest-runner": "^9.4.0",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "jest": "^27.3.1",
    "neostandard": "^0.13.0"
  },
  "jest": {
    "collectCoverage": true,
    "roots": [
      "<rootDir>/src/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 95,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    }
  },
  "dependencies": {
    "esm": "^3.2.25",
    "seedrandom": "^2.4.4",
    "yargs": "^17.5.1"
  }
}
